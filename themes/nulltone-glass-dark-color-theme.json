{
  "$schema": "vscode://schemas/color-theme",
  "name": "OS Nulltone Glass Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0D0D0DF5",
    "editor.foreground": "#F2F2F2",
    "editor.selectionBackground": "#007ACC44",
    "editor.selectionHighlightBackground": "#007ACC22",
    "editor.wordHighlightBackground": "#007ACC1A",
    "editor.wordHighlightStrongBackground": "#007ACC33",
    "editor.findMatchBackground": "#D7BA7D44",
    "editor.findMatchHighlightBackground": "#D7BA7D22",
    "editor.lineHighlightBackground": "#FFFFFF08",
    "editor.lineHighlightBorder": "#FFFFFF10",
    "editorCursor.foreground": "#3794FF",
    "editorWhitespace.foreground": "#2E2E2E",
    "editorIndentGuide.background": "#1F1F1F",
    "editorIndentGuide.activeBackground": "#2A2A2A",
    "editorLineNumber.foreground": "#4A4A4A",
    "editorLineNumber.activeForeground": "#888888",
    "editorGutter.background": "#0D0D0DF2",
    "editorRuler.foreground": "#1F1F1F",
    "editorBracketMatch.background": "#007ACC33",
    "editorBracketMatch.border": "#007ACC88",
    "editorOverviewRuler.border": "#1A1A1A",
    "editorOverviewRuler.findMatchForeground": "#D7BA7D88",
    "editorOverviewRuler.selectionHighlightForeground": "#007ACC88",
    "activityBar.background": "#0A0A0AE0",
    "activityBar.foreground": "#C8C8C8",
    "activityBar.inactiveForeground": "#555555",
    "activityBar.border": "#1A1A1ACC",
    "activityBarBadge.background": "#007ACC",
    "activityBarBadge.foreground": "#FFFFFF",
    "sideBar.background": "#121212DC",
    "sideBar.foreground": "#B8B8B8",
    "sideBar.border": "#1F1F1FCC",
    "sideBarTitle.foreground": "#888888",
    "sideBarSectionHeader.background": "#121212CC",
    "sideBarSectionHeader.foreground": "#888888",
    "sideBarSectionHeader.border": "#1F1F1FCC",
    "list.activeSelectionBackground": "#007ACC33",
    "list.activeSelectionForeground": "#F2F2F2",
    "list.inactiveSelectionBackground": "#1C1C1CCC",
    "list.inactiveSelectionForeground": "#B8B8B8",
    "list.hoverBackground": "#1A1A1ACC",
    "list.hoverForeground": "#D0D0D0",
    "list.focusBackground": "#007ACC22",
    "list.highlightForeground": "#3794FF",
    "titleBar.activeBackground": "#161616D9",
    "titleBar.activeForeground": "#B8B8B8",
    "titleBar.inactiveBackground": "#11111199",
    "titleBar.inactiveForeground": "#666666",
    "titleBar.border": "#1A1A1ACC",
    "editorGroupHeader.tabsBackground": "#0F0F0FD9",
    "editorGroupHeader.tabsBorder": "#1A1A1ACC",
    "tab.activeBackground": "#0D0D0DF2",
    "tab.activeForeground": "#F2F2F2",
    "tab.activeBorder": "#007ACC",
    "tab.activeBorderTop": "#007ACC",
    "tab.inactiveBackground": "#161616BB",
    "tab.inactiveForeground": "#777777",
    "tab.border": "#1A1A1ACC",
    "tab.hoverBackground": "#1A1A1ACC",
    "tab.unfocusedActiveForeground": "#AAAAAA",
    "statusBar.background": "#007ACCE6",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#0066AAC0",
    "statusBar.noFolderBackground": "#444444",
    "statusBar.debuggingBackground": "#C34040",
    "statusBarItem.hoverBackground": "#0088DD",
    "statusBarItem.activeBackground": "#0088DD",
    "panel.background": "#0F0F0FF2",
    "panel.border": "#1A1A1ACC",
    "panelTitle.activeForeground": "#F2F2F2",
    "panelTitle.activeBorder": "#007ACC",
    "panelTitle.inactiveForeground": "#666666",
    "terminal.background": "#0D0D0DF7",
    "terminal.foreground": "#F2F2F2",
    "terminal.ansiBlack": "#1A1A1A",
    "terminal.ansiBlue": "#3794FF",
    "terminal.ansiBrightBlack": "#555555",
    "terminal.ansiBrightBlue": "#4EA1FF",
    "terminal.ansiBrightCyan": "#4EC9B0",
    "terminal.ansiBrightGreen": "#B5CEA8",
    "terminal.ansiBrightMagenta": "#C586C0",
    "terminal.ansiBrightRed": "#F14C4C",
    "terminal.ansiBrightWhite": "#F2F2F2",
    "terminal.ansiBrightYellow": "#D7BA7D",
    "terminal.ansiCyan": "#4EC9B0",
    "terminal.ansiGreen": "#B5CEA8",
    "terminal.ansiMagenta": "#C586C0",
    "terminal.ansiRed": "#F14C4C",
    "terminal.ansiWhite": "#D4D4D4",
    "terminal.ansiYellow": "#D7BA7D",
    "terminal.selectionBackground": "#007ACC44",
    "terminal.border": "#1A1A1A",
    "terminalCursor.foreground": "#3794FF",
    "input.background": "#1A1A1AF0",
    "input.foreground": "#F2F2F2",
    "input.border": "#2A2A2A",
    "input.placeholderForeground": "#555555",
    "inputOption.activeBorder": "#007ACC",
    "inputOption.activeBackground": "#007ACC33",
    "dropdown.background": "#1A1A1AF0",
    "dropdown.foreground": "#F2F2F2",
    "dropdown.border": "#2A2A2A",
    "button.background": "#007ACC",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#0088DD",
    "button.secondaryBackground": "#2A2A2AE6",
    "button.secondaryForeground": "#D0D0D0",
    "badge.background": "#007ACC",
    "badge.foreground": "#FFFFFF",
    "progressBar.background": "#007ACC",
    "scrollbar.shadow": "#00000066",
    "scrollbarSlider.background": "#2A2A2A88",
    "scrollbarSlider.hoverBackground": "#3A3A3A",
    "scrollbarSlider.activeBackground": "#007ACC88",
    "menu.background": "#161616F0",
    "menu.foreground": "#D0D0D0",
    "menu.selectionBackground": "#007ACC44",
    "menu.selectionForeground": "#F2F2F2",
    "menu.border": "#2A2A2A",
    "menu.separatorBackground": "#2A2A2A",
    "menubar.selectionBackground": "#1A1A1AD9",
    "menubar.selectionForeground": "#F2F2F2",
    "quickInput.background": "#141414F2",
    "quickInput.foreground": "#F2F2F2",
    "quickInputList.focusBackground": "#007ACC33",
    "focusBorder": "#007ACC",
    "selection.background": "#007ACC44",
    "widget.shadow": "#00000088",
    "notifications.background": "#161616F2",
    "notifications.foreground": "#D0D0D0",
    "notifications.border": "#2A2A2A",
    "notificationToast.border": "#2A2A2A",
    "diffEditor.insertedTextBackground": "#B5CEA81A",
    "diffEditor.removedTextBackground": "#F14C4C1A",
    "gitDecoration.addedResourceForeground": "#B5CEA8",
    "gitDecoration.modifiedResourceForeground": "#D7BA7D",
    "gitDecoration.deletedResourceForeground": "#F14C4C",
    "gitDecoration.untrackedResourceForeground": "#4EC9B0",
    "gitDecoration.ignoredResourceForeground": "#555555",
    "gitDecoration.conflictingResourceForeground": "#F14C4C",
    "editorError.foreground": "#F14C4C",
    "editorWarning.foreground": "#D7BA7D",
    "editorInfo.foreground": "#3794FF",
    "editorHint.foreground": "#4EC9B0",
    "peekView.border": "#007ACC",
    "peekViewEditor.background": "#0F0F0FF2",
    "peekViewEditor.matchHighlightBackground": "#D7BA7D33",
    "peekViewResult.background": "#121212F0",
    "peekViewResult.selectionBackground": "#007ACC33",
    "peekViewTitle.background": "#141414F0",
    "peekViewTitleLabel.foreground": "#F2F2F2",
    "peekViewTitleDescription.foreground": "#8C8C8C",
    "breadcrumb.foreground": "#666666",
    "breadcrumb.focusForeground": "#B8B8B8",
    "breadcrumb.activeSelectionForeground": "#F2F2F2",
    "breadcrumbPicker.background": "#161616F2",
    "notebook.editorBackground": "#0D0D0DF5",
    "notebook.cellEditorBackground": "#0D0D0DF5",
    "notebook.focusedCellBackground": "#0D0D0DF5",
    "notebook.selectedCellBackground": "#FFFFFF08",
    "notebook.cellBorderColor": "#FFFFFF14",
    "notebook.focusedCellBorder": "#007ACC88",
    "notebook.inactiveFocusedCellBorder": "#FFFFFF22"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8C8C8C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Keywords (TODO, FIXME, NOTE)",
      "scope": [
        "comment keyword",
        "comment storage.type"
      ],
      "settings": {
        "foreground": "#8C8C8C",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "Numbers & Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "name": "Boolean & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#3794FF"
      }
    },
    {
      "name": "Import / Export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#3794FF"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#4EA1FF"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#E0C79A"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "meta.return-type",
        "meta.type.annotation",
        "storage.type.class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "TypeScript Type Keywords",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "entity.name.type.alias",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#D0D0D0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#F2F2F2"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.arithmetic",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#858585"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#3794FF"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "HTML Attribute Values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "CSS Property Names",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "CSS Property Values",
      "scope": [
        "meta.property-value",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#4EA1FF"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#3794FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#F2F2F2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#D0D0D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#4EA1FF"
      }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#F14C4C"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#4EC9B0",
    "interface": "#4EC9B0",
    "type": "#4EC9B0",
    "enum": "#4EC9B0",
    "typeParameter": "#4EC9B0",
    "function": "#4EA1FF",
    "method": "#4EA1FF",
    "macro": "#C586C0",
    "variable": "#F2F2F2",
    "variable.readonly": "#B5CEA8",
    "property": "#D0D0D0",
    "parameter": "#E0C79A",
    "namespace": "#4EC9B0",
    "comment": {
      "foreground": "#8C8C8C",
      "italic": true
    }
  }
}
